{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "types": ["node", "express"],
    "typeRoots": ["./src/types", "./node_modules/@types"],
    //"noUnusedLocals": true,
    //"noUnusedParameters": true,
    //"noImplicitReturns": true
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
